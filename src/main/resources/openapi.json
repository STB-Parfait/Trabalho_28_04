{
  "openapi": "3.0.3",
  "info": {
    "title": "Agenda API",
    "description": "REST API for managing contacts and appointments. Built with pure Java HttpServer, Jackson, JDBC, MySQL, and Docker.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Local Docker server"
    }
  ],
  "tags": [
    {
      "name": "Contacts",
      "description": "Contact CRUD operations"
    },
    {
      "name": "Appointments",
      "description": "Appointment CRUD operations and business rules"
    },
    {
      "name": "Reports",
      "description": "Internal HTTP integration reports"
    }
  ],
  "paths": {
    "/contacts": {
      "get": {
        "tags": ["Contacts"],
        "summary": "List contacts",
        "responses": {
          "200": {
            "description": "Contacts returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Contact"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Contacts"],
        "summary": "Create a contact",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContactRequest"
              },
              "example": {
                "name": "Maria Silva",
                "email": "maria@example.com",
                "phone": "(11) 99999-0000"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Contact created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Contact"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/contacts/{id}": {
      "get": {
        "tags": ["Contacts"],
        "summary": "Get a contact by id",
        "parameters": [
          {
            "$ref": "#/components/parameters/Id"
          }
        ],
        "responses": {
          "200": {
            "description": "Contact returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Contact"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "put": {
        "tags": ["Contacts"],
        "summary": "Update a contact",
        "parameters": [
          {
            "$ref": "#/components/parameters/Id"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContactRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contact updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Contact"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "delete": {
        "tags": ["Contacts"],
        "summary": "Delete a contact",
        "parameters": [
          {
            "$ref": "#/components/parameters/Id"
          }
        ],
        "responses": {
          "204": {
            "description": "Contact deleted"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/appointments": {
      "get": {
        "tags": ["Appointments"],
        "summary": "List appointments",
        "responses": {
          "200": {
            "description": "Appointments returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Appointment"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Appointments"],
        "summary": "Create an appointment",
        "description": "Blocks overlapping appointments for the same contact unless the appointment is canceled.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AppointmentRequest"
              },
              "example": {
                "contactId": 1,
                "title": "Project meeting",
                "description": "Discuss ISS A2 implementation",
                "startsAt": "2026-04-28T14:00:00",
                "endsAt": "2026-04-28T15:00:00"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Appointment created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Appointment"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/appointments/{id}": {
      "get": {
        "tags": ["Appointments"],
        "summary": "Get an appointment by id",
        "parameters": [
          {
            "$ref": "#/components/parameters/Id"
          }
        ],
        "responses": {
          "200": {
            "description": "Appointment returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Appointment"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "put": {
        "tags": ["Appointments"],
        "summary": "Update an appointment",
        "parameters": [
          {
            "$ref": "#/components/parameters/Id"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AppointmentRequest"
              },
              "example": {
                "contactId": 1,
                "title": "Project meeting",
                "description": "Updated agenda description",
                "startsAt": "2026-04-28T14:00:00",
                "endsAt": "2026-04-28T15:00:00",
                "status": "CANCELED"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Appointment updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Appointment"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "delete": {
        "tags": ["Appointments"],
        "summary": "Delete an appointment",
        "parameters": [
          {
            "$ref": "#/components/parameters/Id"
          }
        ],
        "responses": {
          "204": {
            "description": "Appointment deleted"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/reports/agenda-summary": {
      "get": {
        "tags": ["Reports"],
        "summary": "Get agenda summary",
        "description": "Consumes the internal contacts and appointments endpoints through HTTP and returns aggregate data.",
        "responses": {
          "200": {
            "description": "Summary returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgendaSummary"
                }
              }
            }
          },
          "502": {
            "description": "Internal HTTP integration failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "Id": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer",
          "format": "int64",
          "minimum": 1
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Validation error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiError"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiError"
            }
          }
        }
      }
    },
    "schemas": {
      "Contact": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "Maria Silva"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "maria@example.com"
          },
          "phone": {
            "type": "string",
            "example": "(11) 99999-0000"
          }
        }
      },
      "ContactRequest": {
        "type": "object",
        "required": ["name", "email", "phone"],
        "properties": {
          "name": {
            "type": "string",
            "example": "Maria Silva"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "maria@example.com"
          },
          "phone": {
            "type": "string",
            "example": "(11) 99999-0000"
          }
        }
      },
      "Appointment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "contactId": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "title": {
            "type": "string",
            "example": "Project meeting"
          },
          "description": {
            "type": "string",
            "example": "Discuss ISS A2 implementation"
          },
          "startsAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-04-28T14:00:00"
          },
          "endsAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-04-28T15:00:00"
          },
          "status": {
            "$ref": "#/components/schemas/AppointmentStatus"
          },
          "durationMinutes": {
            "type": "integer",
            "format": "int64",
            "example": 60
          }
        }
      },
      "AppointmentRequest": {
        "type": "object",
        "required": ["contactId", "title", "startsAt", "endsAt"],
        "properties": {
          "contactId": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "title": {
            "type": "string",
            "example": "Project meeting"
          },
          "description": {
            "type": "string",
            "example": "Discuss ISS A2 implementation"
          },
          "startsAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-04-28T14:00:00"
          },
          "endsAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-04-28T15:00:00"
          },
          "status": {
            "$ref": "#/components/schemas/AppointmentStatus"
          }
        }
      },
      "AppointmentStatus": {
        "type": "string",
        "enum": ["SCHEDULED", "TODAY", "PAST", "CANCELED"]
      },
      "AgendaSummary": {
        "type": "object",
        "properties": {
          "totalContacts": {
            "type": "integer",
            "example": 1
          },
          "totalAppointments": {
            "type": "integer",
            "example": 2
          },
          "scheduledAppointments": {
            "type": "integer",
            "example": 1
          },
          "todayAppointments": {
            "type": "integer",
            "example": 0
          },
          "pastAppointments": {
            "type": "integer",
            "example": 1
          },
          "canceledAppointments": {
            "type": "integer",
            "example": 0
          }
        }
      },
      "ApiError": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer",
            "example": 400
          },
          "error": {
            "type": "string",
            "example": "Email format is invalid."
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "example": "2026-04-26T16:01:16"
          }
        }
      }
    }
  }
}
